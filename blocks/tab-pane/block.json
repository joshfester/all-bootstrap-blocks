{
	"apiVersion": 2,
	"name": "areoi/tab-pane",
	"title": "Tab Pane",
	"parent": [ "areoi/div" ],
	"category": "areoi-components",
	"description": "A single tab pane. Holds the content shown when its matching tab is activated.",
	"textdomain": "default",
	"keywords": [ "areoi", "bootstrap", "tab", "tabs" ],
	"example": {
		"attributes": {
			"preview": true
		}
	},
	"attributes": {
		"preview": {
			"type": "boolean",
			"default": false
		},
		"anchor": {
			"type": "string",
			"default": false
		},
		"block_id": {
			"type": "string",
			"default": null
		},
		"active": {
			"type": "boolean",
			"default": false
		},
		"labelledby": {
			"type": "string",
			"default": null
		},

		"hide_xs": {
			"type": "boolean",
			"default": false
		},
		"hide_sm": {
			"type": "boolean",
			"default": false
		},
		"hide_md": {
			"type": "boolean",
			"default": false
		},
		"hide_lg": {
			"type": "boolean",
			"default": false
		},
		"hide_xl": {
			"type": "boolean",
			"default": false
		},
		"hide_xxl": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"anchor": true,
		"align": false,
		"html": false
	},
	"editorScript": "areoi-blocks",
    "editorStyle": "file:./index.css",
    "style": "file:../../build/style.css"
}
